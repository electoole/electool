# Storage
# MySQL is required. The app fails startup if these are missing or unreachable.
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_SSL_CA=
MYSQL_SSL_CA_CONTENT=
MYSQL_SSL_DISABLED=false
MYSQL_STRICT=true

# All MySQL tables will be created with this prefix to avoid collisions.
DB_TABLE_PREFIX=eii_

# Flask/security
SECRET_KEY=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# Use false for local http://localhost. Set true in production HTTPS.
SESSION_COOKIE_SECURE=false
MAX_UPLOAD_MB=10

# AI assistant
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_REQUESTS_PER_MINUTE_PER_KEY=2
GROQ_REQUESTS_PER_DAY_PER_KEY=100

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_REQUESTS_PER_MINUTE=8
